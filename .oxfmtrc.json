{
	"$schema": "https://unpkg.com/oxfmt/configuration_schema.json",
	"trailingComma": "all",
	"useTabs": true,
	"tabWidth": 2,
	"printWidth": 110,
	"semi": true,
	"singleQuote": true,
	"bracketSpacing": true,
	"jsdoc": {
		"capitalizeDescriptions": false
	},
	"sortImports": {
		"groups": [
			["side_effect", "side_effect_style"],
			"builtin",
			"react",
			{ "newlinesBetween": false },
			"expo",
			{ "newlinesBetween": false },
			"external",
			"lib",
			"state",
			"logger",
			"platform",
			"locale",
			"view",
			"screens",
			"alf",
			"components",
			["internal", "subpath"],
			["parent", "sibling", "index"],
			"unknown"
		],
		"customGroups": [
			{
				"groupName": "react",
				"elementNamePattern": [
					"react",
					"react/**",
					"react-native",
					"react-native/**",
					"react-native-*",
					"react-native-*/**"
				]
			},
			{
				"groupName": "expo",
				"elementNamePattern": ["expo", "expo/**", "expo-*", "expo-*/**"]
			},
			{
				"groupName": "lib",
				"elementNamePattern": ["#/lib", "#/lib/**"]
			},
			{
				"groupName": "state",
				"elementNamePattern": ["#/state", "#/state/**"]
			},
			{
				"groupName": "logger",
				"elementNamePattern": ["#/logger", "#/logger/**"]
			},
			{
				"groupName": "platform",
				"elementNamePattern": ["#/platform", "#/platform/**"]
			},
			{
				"groupName": "locale",
				"elementNamePattern": ["#/locale", "#/locale/**"]
			},
			{
				"groupName": "view",
				"elementNamePattern": ["#/view", "#/view/**"]
			},
			{
				"groupName": "screens",
				"elementNamePattern": ["#/screens", "#/screens/**"]
			},
			{
				"groupName": "alf",
				"elementNamePattern": ["#/alf", "#/alf/**"]
			},
			{
				"groupName": "components",
				"elementNamePattern": ["#/components", "#/components/**"]
			}
		]
	},
	"ignorePatterns": ["pnpm-lock.yaml", "src/locale/locales"],
	"overrides": [
		{
			"files": ["tsconfig*.json"],
			"options": { "parser": "jsonc" }
		},
		{
			"files": ["*.md"],
			"options": { "printWidth": 100, "proseWrap": "always" }
		}
	]
}
