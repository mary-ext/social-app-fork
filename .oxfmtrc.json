{
	"$schema": "https://unpkg.com/oxfmt/configuration_schema.json",
	"trailingComma": "all",
	"useTabs": true,
	"tabWidth": 2,
	"printWidth": 110,
	"semi": true,
	"singleQuote": true,
	"bracketSpacing": true,
	"jsdoc": {
		"capitalizeDescriptions": false
	},
	"ignorePatterns": ["pnpm-lock.yaml", "src/locale/locales"],
	"overrides": [
		{
			"files": ["tsconfig*.json"],
			"options": { "parser": "jsonc" }
		},
		{
			"files": ["*.md"],
			"options": { "printWidth": 100, "proseWrap": "always" }
		}
	]
}
