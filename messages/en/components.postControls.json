		{
			"declarations": [
				"input count",
				"local cp = count: plural"
			],
			"selectors": [
				"cp"
			],
			"match": {
				"cp=one": "Reply ({count} reply)",
				"cp=other": "Reply ({count} replies)"
			}
		}
	],
	"components.postControls.a11y.repost": "Repost or quote post",
	"components.postControls.a11y.unlike": [
		{
			"declarations": [
				"input count",
				"local cp = count: plural"
			],
			"selectors": [
				"cp"
			],
			"match": {
				"cp=one": "Unlike ({count} like)",
				"cp=other": "Unlike ({count} likes)"
			}
		}
	],
