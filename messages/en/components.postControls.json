{
	"$schema": "https://inlang.com/schema/inlang-message-format",
	"components.postControls.a11y.like": [
		{
			"declarations": [
				"input count",
				"local cp = count: plural"
			],
			"selectors": [
				"cp"
			],
			"match": {
				"cp=one": "Like ({count} like)",
				"cp=other": "Like ({count} likes)"
			}
		}
	],
	"components.postControls.a11y.openOptions": "Open post options menu",
	"components.postControls.a11y.openShare": "Open share menu",
