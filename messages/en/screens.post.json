{
	"$schema": "https://inlang.com/schema/inlang-message-format",
	"screens.post.like.count": [
		{
			"declarations": ["input count", "local n = count: number", "local cp = count: plural"],
			"selectors": ["cp"],
			"match": {
				"cp=one": "{n} like",
				"cp=other": "{n} likes"
			}
		}
	],
	"screens.post.quote.count": [
		{
			"declarations": ["input count", "local n = count: number", "local cp = count: plural"],
			"selectors": ["cp"],
			"match": {
				"cp=one": "{n} quote",
				"cp=other": "{n} quotes"
			}
		}
	],
	"screens.post.repost.count": [
		{
			"declarations": ["input count", "local n = count: number", "local cp = count: plural"],
			"selectors": ["cp"],
			"match": {
				"cp=one": "{n} repost",
				"cp=other": "{n} reposts"
			}
		}
	],
	"screens.post.repost.title": "Reposted by"
}
