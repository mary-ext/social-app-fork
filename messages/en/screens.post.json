{
	"$schema": "https://inlang.com/schema/inlang-message-format",
	"screens.post.like.count": [
		{
			"declarations": ["input count", "local cp = count: plural"],
			"selectors": ["cp"],
			"match": {
				"cp=one": "{count} like",
				"cp=other": "{count} likes"
			}
		}
	],
	"screens.post.quote.count": [
		{
			"declarations": ["input count", "local cp = count: plural"],
			"selectors": ["cp"],
			"match": {
				"cp=one": "{count} quote",
				"cp=other": "{count} quotes"
			}
		}
	],
	"screens.post.repost.count": [
		{
			"declarations": ["input count", "local cp = count: plural"],
			"selectors": ["cp"],
			"match": {
				"cp=one": "{count} repost",
				"cp=other": "{count} reposts"
			}
		}
	],
	"screens.post.repost.title": "Reposted By"
}
