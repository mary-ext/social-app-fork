{
	"$schema": "https://inlang.com/schema/inlang-message-format",
	"screens.postThread.archive.from": "Archived from {date}",
	"screens.postThread.archive.label": "Archived post",
	"screens.postThread.dateVerification.createdInfo": "Shows information about when this post was created",
	"screens.postThread.dateVerification.mismatch": "This post claims to have been created on {#t0}{claimed}{/t0}, but was first seen by Bluesky on {#t1}{seen}{/t1}.",
	"screens.postThread.dateVerification.unverified": "Bluesky cannot confirm the authenticity of the claimed date.",
	"screens.postThread.engagement.like.count": [
		{
			"declarations": ["input count", "input formattedCount", "local cp = count: plural"],
			"selectors": ["cp"],
			"match": {
				"cp=one": "{#t0}{formattedCount}{/t0} like",
				"cp=other": "{#t0}{formattedCount}{/t0} likes"
			}
		}
	],
	"screens.postThread.engagement.like.title": "Likes on this post",
	"screens.postThread.engagement.quote.count": [
		{
			"declarations": ["input count", "input formattedCount", "local cp = count: plural"],
			"selectors": ["cp"],
			"match": {
				"cp=one": "{#t0}{formattedCount}{/t0} quote",
				"cp=other": "{#t0}{formattedCount}{/t0} quotes"
			}
		}
	],
	"screens.postThread.engagement.quote.empty": "No quotes yet",
	"screens.postThread.engagement.quote.emptyPrompt": "Nobody has quoted this yet. Maybe you should be the first!",
	"screens.postThread.engagement.quote.endOfFeed": "That's all, folks!",
	"screens.postThread.engagement.quote.title": "Quotes of this post",
	"screens.postThread.engagement.repost.count": [
		{
			"declarations": ["input count", "input formattedCount", "local cp = count: plural"],
			"selectors": ["cp"],
			"match": {
				"cp=one": "{#t0}{formattedCount}{/t0} repost",
				"cp=other": "{#t0}{formattedCount}{/t0} reposts"
			}
		}
	],
	"screens.postThread.engagement.repost.empty": "No reposts yet",
	"screens.postThread.engagement.repost.emptyPrompt": "Nobody has reposted this yet. Maybe you should be the first!",
	"screens.postThread.engagement.repost.title": "Reposts of this post",
	"screens.postThread.engagement.save.count": [
		{
			"declarations": ["input count", "input formattedCount", "local cp = count: plural"],
			"selectors": ["cp"],
			"match": {
				"cp=one": "{#t0}{formattedCount}{/t0} save",
				"cp=other": "{#t0}{formattedCount}{/t0} saves"
			}
		}
	],
	"screens.postThread.post.error.blocked": "Post blocked",
	"screens.postThread.post.error.deleted": "Post has been deleted",
	"screens.postThread.post.error.generic": "Something went wrong. Please try again in a moment.",
	"screens.postThread.post.error.load": "Error loading post",
	"screens.postThread.post.error.notFound": "Post not found",
	"screens.postThread.reply.a11y.compose": "Compose reply",
	"screens.postThread.reply.a11y.opensComposer": "Opens composer",
	"screens.postThread.reply.action.continueThread": "Continue thread",
	"screens.postThread.reply.action.continueThreadMore": "Continue thread...",
	"screens.postThread.reply.action.readMore": "Read more replies",
	"screens.postThread.reply.action.readMoreCount": [
		{
			"declarations": ["input count", "local cp = count: plural"],
			"selectors": ["cp"],
			"match": {
				"cp=one": "Read {count} more reply",
				"cp=other": "Read {count} more replies"
			}
		}
	],
	"screens.postThread.reply.action.showMore": "Show more replies",
	"screens.postThread.threadOptions.display.label": "Show replies as",
	"screens.postThread.threadOptions.display.linear": "Linear",
	"screens.postThread.threadOptions.display.threaded": "Threaded",
	"screens.postThread.threadOptions.label": "Thread options",
	"screens.postThread.threadOptions.sorting": "Reply sorting",
	"screens.postThread.visibility.signedInOnly": "This author has chosen to make their posts visible only to people who are signed in."
}
