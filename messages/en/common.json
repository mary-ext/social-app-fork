	"common.count.followers": [
		{
			"declarations": ["input count", "local cp = count: plural"],
			"selectors": ["cp"],
			"match": {
				"cp=one": "follower",
				"cp=other": "followers"
			}
		}
	],
	"common.count.following": [
		{
			"declarations": ["input count", "local cp = count: plural"],
			"selectors": ["cp"],
			"match": {
				"cp=one": "following",
				"cp=other": "following"
			}
		}
	],
	"common.count.likedBy": [
		{
			"declarations": ["input count", "local cp = count: plural"],
			"selectors": ["cp"],
			"match": {
				"cp=one": "Liked by {count} user",
				"cp=other": "Liked by {count} users"
			}
		}
	],
	"common.count.members": [
		{
			"declarations": ["input limit", "input count", "local cp = limit: plural"],
			"selectors": ["cp"],
			"match": {
				"cp=one": "{count}/{limit} member",
				"cp=other": "{count}/{limit} members"
			}
		}
	],
