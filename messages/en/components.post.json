{
	"$schema": "https://inlang.com/schema/inlang-message-format",
	"components.post.external.a11y.play": "Play {title}",
	"components.post.external.a11y.player": "Embedded player",
	"components.post.image.a11y.carousel": "carousel",
	"components.post.image.a11y.gallery": [
		{
			"declarations": ["input count", "local cp = count: plural", "local n = count: number"],
			"selectors": ["cp"],
			"match": {
				"cp=one": "Image gallery, {n} image",
				"cp=other": "Image gallery, {n} images"
			}
		}
	],
	"components.post.image.a11y.imagePosition": [
		{
			"declarations": [
				"input index",
				"input imageCount",
				"local n1 = index: number",
				"local n2 = imageCount: number"
			],
			"selectors": [],
			"match": {
				"": "Image {n1} of {n2}"
			}
		}
	],
	"components.post.image.a11y.slide": "slide",
	"components.post.publication.action.subscribe": "Subscribe on {name}",
	"components.post.publication.action.subscribeTo": "Subscribe to {title} on {name}",
	"components.post.publication.action.view": "View publication",
	"components.post.publication.action.viewSource": "View {title}",
	"components.post.publication.action.viewTitle": "View {title}",
	"components.post.publication.byAuthor": "by @{handle}",
	"components.post.publication.readingTime": [
		{
			"declarations": ["input readingTime", "local cp = readingTime: plural"],
			"selectors": ["cp"],
			"match": {
				"cp=one": "{readingTime}m",
				"cp=other": "{readingTime}m"
			}
		}
	],
	"components.post.reply.to": "Replied to {#t0/}",
	"components.post.reply.toBlocked": "Replied to a blocked post",
	"components.post.reply.toPost": "Replied to a post",
	"components.post.reply.toYou": "Replied to you",
	"components.post.state.blocked": "Blocked",
	"components.post.state.deleted": "Deleted",
	"components.post.state.removedByAuthor": "Removed by author",
	"components.post.state.removedByYou": "Removed by you",
	"components.post.text.expand": "Expand post text",
	"components.post.text.showMore": "Show more",
	"components.post.video.a11y.pause": "Pause video",
	"components.post.video.a11y.play": "Play video",
	"components.post.video.a11y.player": "Embedded video player",
	"components.post.video.a11y.seekSlider": "Seek slider. Use the arrow keys to seek forwards and backwards, and space to play/pause",
	"components.post.video.a11y.timeProgress": "{currentTime} of {duration}",
	"components.post.video.a11y.timeRemaining": [
		{
			"declarations": ["input time", "local cp = time: plural"],
			"selectors": ["cp"],
			"match": {
				"cp=one": "Time remaining: {time} second",
				"cp=other": "Time remaining: {time} seconds"
			}
		}
	],
	"components.post.video.a11y.unmute": "Unmute video",
	"components.post.video.a11y.volume": "Volume",
	"components.post.video.action.enterFullscreen": "Enter fullscreen",
	"components.post.video.action.exitFullscreen": "Exit fullscreen",
	"components.post.video.action.pause": "Pause",
	"components.post.video.action.play": "Play",
	"components.post.video.captions.disable": "Disable captions",
	"components.post.video.captions.enable": "Enable captions",
	"components.post.video.error.generic": "An error occurred",
	"components.post.video.error.load": "An error occurred while loading the video. Please try again.",
	"components.post.video.error.notFound": "Video not found.",
	"components.post.video.error.unsupportedCodec": "This video can’t be played on your device. Your browser or system may be missing the required video codecs (H.264/AAC)."
}
