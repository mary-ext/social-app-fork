{
	"name": "bsky.app",
	"version": "1.122.0",
	"private": true,
	"type": "module",
	"scripts": {
		"postinstall": "pnpm paraglide:compile && pnpm cf-typegen",
		"dev": "rsbuild dev",
		"dev:worker": "wrangler dev",
		"deploy": "wrangler deploy",
		"cf-typegen": "wrangler types",
		"build": "pnpm paraglide:compile && pnpm lint && rsbuild build",
		"paraglide:compile": "node scripts/compile-i18n.ts",
		"preview": "rsbuild preview",
