  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@babel/runtime": "^7.26.0",
    "@eslint/js": "^9.39.2",
    "@lingui/babel-plugin-lingui-macro": "^5.9.2",
    "@lingui/cli": "^5.9.2",
    "@react-native/babel-preset": "0.81.5",
    "@react-native/typescript-config": "^0.81.5",
    "@rsbuild/core": "^2.0.6",
