{
	"name": "bsky.app",
	"version": "1.122.0",
	"private": true,
	"scripts": {
		"postinstall": "pnpm intl:compile-if-needed && pnpm cf-typegen",
		"dev": "rsbuild dev",
		"dev:worker": "wrangler dev",
		"deploy": "wrangler deploy",
		"cf-typegen": "wrangler types",
		"build": "pnpm typecheck && rsbuild build",
		"preview": "rsbuild preview",
		"lint": "eslint --cache src",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"typecheck": "tsgo -b",
		"intl:build": "pnpm intl:extract && pnpm intl:compile",
		"intl:extract": "lingui extract --clean --locale en",
		"intl:compile": "lingui compile",
		"intl:compile-if-needed": "[ -f src/locale/locales/en/messages.ts ] || pnpm intl:compile",
		"icons:optimize": "svgo -f ./assets/icons",
		"nuke": "rm -rf ./node_modules ./web-build"
	},
	"dependencies": {
		"@atcute/atproto": "4.0.2",
		"@atcute/bluesky": "4.0.10",
		"@atcute/bluesky-moderation": "^4.2.0",
		"@atcute/bluesky-richtext-builder": "^4.0.0",
		"@atcute/bluesky-richtext-parser": "^2.1.1",
		"@atcute/bluesky-richtext-segmenter": "^3.0.0",
		"@atcute/bluesky-search-parser": "^0.1.2",
		"@atcute/cbor": "^2.3.4",
		"@atcute/cid": "^2.4.1",
		"@atcute/client": "^5.1.0",
		"@atcute/germ": "1.0.1",
		"@atcute/identity-resolver": "^2.0.0",
		"@atcute/lexicons": "^2.0.1",
		"@atcute/microcosm": "^2.0.1",
		"@atcute/oauth-browser-client": "^4.0.0",
		"@atcute/oauth-cab": "^0.1.0",
		"@atcute/ozone": "4.0.4",
		"@atcute/tid": "^1.1.2",
		"@atcute/util-text": "^1.3.1",
		"@atcute/xrpc-server": "^2.0.0",
		"@base-ui/react": "^1.6.0",
		"@braintree/sanitize-url": "^7.1.2",
		"@emoji-mart/data": "^1.2.1",
		"@floating-ui/react-dom": "^2.1.8",
		"@lingui/core": "^6.4.0",
		"@lingui/react": "^6.4.0",
		"@mary-ext/simple-event-emitter": "^1.0.2",
		"@mary/color-fns": "jsr:^0.1.3",
		"@mary/date-fns": "jsr:^0.1.4",
		"@mary/exif-rm": "jsr:^0.2.2",
		"@oomfware/lang-detect": "^0.2.1",
