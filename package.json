		"react-native-web": "^0.21.2",
		"react-remove-scroll-bar": "^2.3.8",
		"tldts": "^7.4.3"
	},
	"devDependencies": {
		"@babel/core": "^7.29.7",
		"@babel/plugin-transform-typescript": "^7.29.7",
		"@eslint/js": "^9.39.4",
		"@lingui/babel-plugin-lingui-macro": "^6.4.0",
