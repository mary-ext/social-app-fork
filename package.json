    "radix-ui": "^1.4.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hotkeys-hook": "5.2.4",
    "react-image-crop": "^11.0.7",
    "react-native": "0.81.5",
    "react-native-edge-to-edge": "^1.6.0",
    "react-native-progress": "bluesky-social/react-native-progress",
    "react-native-qrcode-styled": "^0.3.3",
