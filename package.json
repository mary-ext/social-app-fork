		"@tanstack/react-query": "^5.101.0",
		"@tanstack/react-query-persist-client": "^5.101.0",
		"@vanilla-extract/css": "^1.20.1",
		"@vanilla-extract/dynamic": "^2.1.5",
		"bcp-47-match": "^2.0.3",
		"clsx": "^2.1.1",
		"date-fns": "^4.4.0",
		"emoji-regex": "^10.6.0",
		"fast-deep-equal": "^3.1.3",
