		"svgo": "^4.0.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"wrangler": "^4.103.0"
	},
	"browserslist": {
		"production": [
			"last 2 chrome versions",
			"last 2 edge versions",
			"last 2 firefox versions",
			"last 2 safari versions"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	},
	"engines": {
		"node": ">=24.15.0"
	}
}
