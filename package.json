{
	"name": "bsky.app",
	"version": "1.122.0",
	"private": true,
	"scripts": {
		"postinstall": "pnpm intl:compile-if-needed && pnpm cf-typegen",
		"dev": "rsbuild dev",
		"dev:worker": "wrangler dev",
		"deploy": "wrangler deploy",
		"cf-typegen": "wrangler types",
		"build": "pnpm typecheck && rsbuild build",
		"preview": "rsbuild preview",
		"lint": "eslint --cache src",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"typecheck": "tsgo -b",
		"intl:build": "pnpm intl:extract && pnpm intl:compile",
		"intl:extract": "lingui extract --clean --locale en",
		"intl:compile": "lingui compile",
		"intl:compile-if-needed": "[ -f src/locale/locales/en/messages.ts ] || pnpm intl:compile",
		"icons:optimize": "svgo -f ./assets/icons",
		"nuke": "rm -rf ./node_modules ./web-build"
	},
	"dependencies": {
