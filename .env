# The env the app is running in e.g. development, production
PUBLIC_ENV=development

# This is the semver release version of the app, pulled from package.json
PUBLIC_RELEASE_VERSION=

# This is the commit hash that the current bundle was made from.
PUBLIC_BUNDLE_IDENTIFIER=

# Should be formatted YYMMDDHH so that it increases for each build.
PUBLIC_BUNDLE_DATE=0

# The log level for the app's logger transports
PUBLIC_LOG_LEVEL=debug

# Enable debug logs for specific logger instances
PUBLIC_LOG_DEBUG=session

# OAuth client metadata URL. Production builds should set this to the public
# metadata URL; the dev server injects a localhost client id automatically.
PUBLIC_OAUTH_CLIENT_ID=

# OAuth redirect URI. Production builds should set this to the public callback
# URL; the dev server injects the local callback URI automatically.
PUBLIC_OAUTH_REDIRECT_URI=

# OAuth scope. The dev server injects this automatically.
PUBLIC_OAUTH_SCOPE=

# microcosm Slingshot service used to resolve identities during OAuth sign-in
PUBLIC_SLINGSHOT_SERVICE_URL=https://slingshot.microcosm.blue

# source code link shown in the desktop right nav
PUBLIC_SOURCE_CODE_URL=https://tangled.org/did:plc:sdgf6fjeih24rhq43zy3vhkc

# Bluesky appview DID
PUBLIC_BLUESKY_PROXY_DID=

# Bluesky appview proxy audience (full `did#service` form), used by the
# @atcute/client clients
PUBLIC_APPVIEW_PROXY_AUDIENCE=did:web:api.bsky.app#bsky_appview

# Chat service DID
PUBLIC_CHAT_PROXY_DID=

#
#
# Bluesky specific values
#
#
